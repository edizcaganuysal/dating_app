{
  "expo": {
    "name": "Yuni",
    "slug": "yuni",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "yuni",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#F7F0E7"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Yuni needs access to your photos to add them to your profile.",
          "cameraPermission": "Yuni needs access to your camera to take profile photos and verify your identity."
        }
      ]
    ],
    "newArchEnabled": true,
    "ios": {
      "splash": {
        "backgroundColor": "#F7F0E7"
      }
    },
    "android": {
      "package": "com.yuni.app",
      "splash": {
        "backgroundColor": "#F7F0E7"
      }
    }
  }
}
